{
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboardApproval": true,
  "ignoreDeps": [
    "geoip2/geoip2",
    "maxmind-db/reader",
    "maxmind/web-service-common"
  ],
  "packageRules": [
    {
      "groupName": "Just JS monorepo",
      "matchPackageNames": [
        "/^just-/"
      ]
    },
    {
      "groupName": "testing (JS)",
      "matchPackageNames": [
        "/eslint/",
        "/jest/"
      ]
    },
    {
      "groupName": "testing (PHP)",
      "matchPackageNames": [
        "/roots/wordpress/",
        "/yoast/phpunit-polyfills/",
        "/wp-phpunit/wp-phpunit/",
        "/phpunit/phpunit/"
      ]
    },
    {
      "groupName": "symfony",
      "matchPackageNames": [
        "/symfony/"
      ]
    }
  ]
}
